        <messages/>
        <name>Documentation Section Visibility</name>
        <order/>
        <script><![CDATA[function onLoad() {

    // INITIAL CHECK ON FORM LOAD

    toggleDocumentationSection();

    // RUN AGAIN WHEN LOAN STAGE CHANGES

    g_form.getControl('loan_stage').onchange = function() {

        toggleDocumentationSection();

    };

}

// COMMON FUNCTION

function toggleDocumentationSection() {

    var stage = g_form.getValue('loan_stage');

    if (stage == 'x_documentation_verification') {

        g_form.setSectionDisplay(
            'documentation_verification',
            true
        );

    } else {

        g_form.setSectionDisplay(
            'documentation_verification',
            false
        );

    }

}]]></script>
